# API
API_PORT=8000
LOG_LEVEL=INFO

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ML
MODEL_NAME=blanchefort/rubert-base-cased-sentiment
MODEL_CACHE_DIR=/models
MAX_TEXT_LENGTH=512
USE_ONNX=false

# Database
DATABASE_URL=postgresql+asyncpg://sentiment:sentiment@postgres:5432/sentiment

# UI
API_URL=http://nginx/api
